{
  "name": "curriculum",
  "zh_name": "课程开发平台",
  "version": "1.0.3",
  "description": "Curriculum Developer Platform skill for automating curriculum creation and managing knowledge base files.",
  "zh_description": "课程开发平台技能，用于自动化课程创建和管理知识库文件。",
  "author": "Edu-Claw",
  "homepage": "https://curriculum.ai",
  "tags": ["curriculum", "education", "knowledge", "ai", "OCR", "vectorization"],
  "search_keywords": ["课程开发", "知识库管理", "OCR识别", "向量化处理", "教学素材", "课程生成"],
  "capabilities": [
    "curriculum_creation",
    "knowledge_management",
    "file_processing",
    "OCR_recognition",
    "vectorization",
    "knowledge_base_qa",
    "ppt_generation",
    "transcript_generation"
  ],
  "metadata": {
    "emoji": "📚",
    "category": "education",
    "api_base": "https://edu-staging.njyaoduo.com/api/v1",
    "version_check_url": "https://registry.edu-claw.com/skills/curriculum/version"
  },
  "parameters": {
    "properties": {
      "knowledge_base_query": {
        "type": "string",
        "description": "知识库查询问题，如：'智培通平台'",
        "default": "",
        "zh_name": "检索知识库"
      },
      "document_id": {
        "type": "string",
        "description": "文档ID，用于操作特定文档",
        "default": "",
        "zh_name": "文档ID"
      },
      "curriculum_title": {
        "type": "string",
        "description": "课程标题",
        "default": "",
        "zh_name": "课程标题"
      },
      "curriculum_description": {
        "type": "string",
        "description": "课程描述",
        "default": "",
        "zh_name": "课程描述"
      }
    },
    "required": []
  },
  "environment": {
    "required": ["CURRICULUM_ACCESS_TOKEN"],
    "optional": []
  },
  "usage": "This skill provides API access to the Curriculum Developer Platform, allowing you to manage knowledge base files, process documents with OCR and vectorization, generate curriculum materials, and query the knowledge base.",
  "examples": [
    {
      "description": "Query knowledge base",
      "zh_description": "查询知识库",
      "parameters": {
        "knowledge_base_query": "智培通平台"
      }
    },
    {
      "description": "Process document with OCR and vectorization",
      "zh_description": "使用OCR和向量化处理文档",
      "parameters": {
        "document_id": "4c96fa36-0218-452f-a10c-ebb31f315bc5"
      }
    }
  ],
  "endpoints": {
    "auth": {
      "zh_name": "认证",
      "login": {
        "zh_name": "登录",
        "path": "/auth/login"
      },
      "me": {
        "zh_name": "获取当前用户",
        "path": "/auth/me"
      }
    },
    "knowledge": {
      "zh_name": "知识库",
      "list": {
        "zh_name": "列出文档",
        "path": "/documents/"
      },
      "upload": {
        "zh_name": "上传文档",
        "path": "/documents/"
      },
      "delete": {
        "zh_name": "删除文档",
        "path": "/documents/{id}"
      },
      "download": {
        "zh_name": "下载文档",
        "path": "/org/attachments/{id}/download"
      },
      "state": {
        "zh_name": "文档状态",
        "path": "/documents/{id}/state"
      },
      "run_all": {
        "zh_name": "运行OCR和向量化",
        "path": "/org-admin/documents/{id}/run-all"
      },
      "qa": {
        "zh_name": "知识库检索",
        "path": "/org-admin/documents/qa/"
      }
    },
    "generation": {
      "zh_name": "生成",
      "create_curriculum": {
        "zh_name": "创建课程",
        "path": "/curriculums"
      },
      "generate_outline": {
        "zh_name": "生成大纲",
        "path": "/outlines/generate"
      },
      "generate_ppt": {
        "zh_name": "生成PPT",
        "path": "/outlines/{id}/generate_ppt_async"
      },
      "generate_transcripts": {
        "zh_name": "生成讲解词",
        "path": "/transcripts/generate_async"
      },
      "ppt_status": {
        "zh_name": "PPT生成状态",
        "path": "/outlines/{id}/ppt/status"
      },
      "latest_rendered": {
        "zh_name": "最新渲染PPT",
        "path": "/curriculums/{id}/rendered_ppts/latest"
      }
    }
  }
}
